.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# MLflow local backends (regenerated by the run scripts). The live/scheduled
# backend is the exception: the drift-loop workflow force-adds it to persist it.
mlflow*.db
mlartifacts*/
mlruns/

# Raw Open-Meteo observations are COMMITTED, not ignored: this is the real data
# we gather, so we keep it versioned rather than re-fetching (and possibly losing)
# it. The pages/scheduled workflows rebuild from this cache.

# Generated analysis outputs
outputs/

# Static site: the shell (index.html, app.js) is committed; the data files
# (data.json, the raw-data CSV) are generated at build time and published.
site/data.json
site/krakow_hourly.csv
